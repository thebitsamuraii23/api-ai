TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DATA_ENCRYPTION_KEY=replace_with_fernet_key
DATABASE_PATH=data/bot.db
DEFAULT_LANGUAGE=en
# Provider ids: openai, groq, openrouter, together, deepinfra, google, custom
DEFAULT_PROVIDER=openai
MEMORY_MESSAGES=20
POLLING_TASKS_CONCURRENCY_LIMIT=64
LLM_MAX_CONCURRENCY=24
# Optional comma-separated speech-to-text models (OpenAI-compatible APIs).
# Example: TRANSCRIPTION_MODELS=gpt-4o-mini-transcribe,whisper-1
TRANSCRIPTION_MODELS=
SHARED_API_KEY=your_shared_api_key
SHARED_PROVIDER=groq
SHARED_BASE_URL=
SHARED_TOKEN_QUOTA=5000
# Google AI Studio keys usually start with `AIza...`.

# OpenAI-only: enable built-in web search tool via Responses API.
# Values:
# - OPENAI_WEB_SEARCH: 1/0 (default: 1)
# - OPENAI_WEB_SEARCH_TOOL_CHOICE: auto|required|none (default: auto)
OPENAI_WEB_SEARCH=1
OPENAI_WEB_SEARCH_TOOL_CHOICE=auto

# Provider-agnostic fallback search (runs in the bot process and injects results into the prompt).
# Values:
# - EXTERNAL_WEB_SEARCH_MODE: off|auto|always (default: auto)
# - EXTERNAL_WEB_SEARCH_MAX_RESULTS: 1..8 (default: 5)
EXTERNAL_WEB_SEARCH_MODE=auto
EXTERNAL_WEB_SEARCH_MAX_RESULTS=5

# Where web search is executed:
# - server: perform search from this bot instance (your server/network)
# - openai: use OpenAI built-in web_search tool (OpenAI infrastructure)
# - hybrid: allow both (default behavior depends on other flags)
WEB_SEARCH_BACKEND=server
